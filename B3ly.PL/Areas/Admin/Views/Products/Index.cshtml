@model B3ly.BLL.ViewModels.PaginatedList<B3ly.BLL.ViewModels.ProductVM>
@{ ViewData["Title"] = "Products"; }

<div class="d-flex justify-content-end mb-3">
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Product</a>
</div>

<form asp-action="Index" method="get" class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-sm-4 col-md-3">
                <label class="form-label small fw-semibold">Search</label>
                <input name="search" value="@ViewBag.Search" class="form-control form-control-sm" placeholder="Name or description…" />
            </div>
            <div class="col-sm-3 col-md-2">
                <label class="form-label small fw-semibold">Category</label>
                <select name="categoryId" class="form-select form-select-sm" asp-items="ViewBag.Categories">
                    <option value="">All</option>
                </select>
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold">Min Price</label>
                <input name="minPrice" type="number" step="0.01" min="0" value="@ViewBag.MinPrice" class="form-control form-control-sm" placeholder="0" />
            </div>
            <div class="col-6 col-sm-3 col-md-2">
                <label class="form-label small fw-semibold">Max Price</label>
                <input name="maxPrice" type="number" step="0.01" min="0" value="@ViewBag.MaxPrice" class="form-control form-control-sm" placeholder="any" />
            </div>
            <div class="col-sm-4 col-md-2">
                <label class="form-label small fw-semibold">Sort</label>
                <select name="sort" class="form-select form-select-sm">
                    <option value=""          selected="@(ViewBag.Sort == null)">Default</option>
                    <option value="name_asc"  selected="@(ViewBag.Sort=="name_asc")">Name A-Z</option>
                    <option value="price_asc" selected="@(ViewBag.Sort=="price_asc")">Price ↑</option>
                    <option value="price_desc"selected="@(ViewBag.Sort=="price_desc")">Price ↓</option>
                    <option value="stock_asc" selected="@(ViewBag.Sort=="stock_asc")">Stock ↑</option>
                    <option value="stock_desc"selected="@(ViewBag.Sort=="stock_desc")">Stock ↓</option>
                    <option value="newest"   selected="@(ViewBag.Sort=="newest")">Newest</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">Clear</a>
            </div>
        </div>
    </div>
</form>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent d-flex justify-content-between align-items-center py-2">
        <small class="text-muted">
            Showing <strong>@Model.Items.Count</strong> of <strong>@Model.TotalCount</strong> products
        </small>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Product</th><th>SKU</th><th>Category</th>
                    <th class="text-end">Price</th><th class="text-center">Stock</th>
                    <th class="text-center">Active</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Items) {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(p.ImageUrl ?? "https://placehold.co/40x40?text=P")"
                                     style="width:40px;height:40px;object-fit:cover" class="rounded" />
                                <span class="fw-semibold">@p.Name</span>
                            </div>
                        </td>
                        <td><code class="small">@p.SKU</code></td>
                        <td>@p.CategoryName</td>
                        <td class="text-end fw-semibold">$@p.Price.ToString("F2")</td>
                        <td class="text-center">
                            <span class="badge @(p.StockQuantity <= 5 ? "bg-danger" : "bg-success")">@p.StockQuantity</span>
                        </td>
                        <td class="text-center">
                            @if (p.IsActive) { <span class="badge bg-success">Yes</span> }
                            else { <span class="badge bg-secondary">No</span> }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@p.ProductId" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@p.ProductId" method="post" class="d-inline"
                                  onsubmit="return confirm('Deactivate @p.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1) {
    <nav class="mt-4 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            @for (int i = 1; i <= Model.TotalPages; i++) {
                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-search="@ViewBag.Search"
                       asp-route-categoryId="@ViewBag.CategoryId"
                       asp-route-minPrice="@ViewBag.MinPrice"
                       asp-route-maxPrice="@ViewBag.MaxPrice"
                       asp-route-sort="@ViewBag.Sort"
                       asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
