@model IEnumerable<B3ly.BLL.ViewModels.CategoryVM>
@{ ViewData["Title"] = "Categories"; }

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div></div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Category</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr><th>ID</th><th>Name</th><th>Products</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model) {
                    <tr>
                        <td class="text-muted">#@c.CategoryId</td>
                        <td class="fw-semibold">@c.Name</td>
                        <td><span class="badge bg-primary">@c.ProductCount</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@c.CategoryId" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            @if (c.ProductCount == 0)
                            {
                                <form asp-action="Delete" asp-route-id="@c.CategoryId" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete category @c.Name?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger" disabled
                                        title="Cannot delete: has products">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
