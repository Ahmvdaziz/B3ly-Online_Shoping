@model IEnumerable<B3ly.BLL.ViewModels.CategoryVM>
@{ ViewData["Title"] = "Categories"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <form method="get" id="catFilterForm" class="d-flex gap-2">
        <input type="text" name="search" id="catSearchInput" value="@ViewBag.Search"
               class="form-control form-control-sm" style="width:220px" placeholder="Search by name…"
               autocomplete="off" />
        @if (!string.IsNullOrEmpty(ViewBag.Search as string)) {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </form>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New Category</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr><th>ID</th><th>Name</th><th>Parent</th><th>Products</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model) {
                    <tr>
                        <td class="text-muted">#@c.CategoryId</td>
                        <td class="fw-semibold">@c.Name</td>
                        <td>@(c.ParentCategoryName ?? "-")</td>
                        <td><span class="badge bg-primary">@c.ProductCount</span></td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@c.CategoryId" class="btn btn-sm btn-outline-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@c.CategoryId" method="post" class="d-inline"
                                  onsubmit="return confirm('Delete category @c.Name?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any()) {
                    <tr><td colspan="5" class="text-center text-muted py-4">No categories found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var form = document.getElementById('catFilterForm');
    var searchInput = document.getElementById('catSearchInput');
    var debounceTimer;

    searchInput.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function () { form.submit(); }, 400);
    });
})();
</script>
}
