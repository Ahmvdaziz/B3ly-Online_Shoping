@model B3ly.BLL.ViewModels.CreateCategoryVM
@{ ViewData["Title"] = "Edit Category"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
</div>

<div class="card border-0 shadow-sm" style="max-width:480px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-4">
                <label asp-for="Name" class="form-label fw-semibold">Category Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
</div>

<div class="card border-0 shadow-sm" style="max-width:480px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold">Category Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ParentCategoryId" class="form-label fw-semibold">Parent (optional)</label>
                <select asp-for="ParentCategoryId" asp-items="ViewBag.Parents" class="form-select">
                    <option value="">— Top Level —</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>
