@model B3ly.BLL.ViewModels.AdminOrderIndexVM
@{ ViewData["Title"] = "Orders"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <form method="get" id="ordersFilterForm" class="d-flex gap-2 flex-wrap align-items-center">
        <input type="text" name="search" id="orderSearchInput" value="@Model.SearchQuery"
               class="form-control form-control-sm" style="width:200px"
               placeholder="Order # or customer…" autocomplete="off" />
        <select name="status" id="statusSelect" class="form-select form-select-sm" style="width:160px">
            <option value="">All Statuses</option>
            @foreach (var s in Enum.GetValues<B3ly.DAL.Models.OrderStatus>()) {
                <option value="@s" selected="@(Model.StatusFilter == s.ToString())">@s</option>
            }
        </select>
        @if (!string.IsNullOrEmpty(Model.StatusFilter) || !string.IsNullOrEmpty(Model.SearchQuery)) {
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        }
    </form>
    <span class="text-muted small">@Model.Orders.Count() order(s)</span>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Order #</th><th>Customer</th><th>Date</th>
                    <th>Status</th><th class="text-end">Total</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model.Orders) {
                    var bc = o.Status switch {
                        "Pending"    => "bg-warning text-dark",
                        "Processing" => "bg-info text-dark",
                        "Shipped"    => "bg-primary",
                        "Delivered"  => "bg-success",
                        "Cancelled"  => "bg-danger",
                        _            => "bg-secondary"
                    };
                    <tr>
                        <td><strong>@o.OrderNumber</strong></td>
                        <td>
                            @o.CustomerName
                            <br /><small class="text-muted">@o.CustomerEmail</small>
                        </td>
                        <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge @bc">@o.Status</span></td>
                        <td class="text-end fw-bold">$@o.TotalAmount.ToString("F2")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@o.OrderId"
                               class="btn btn-sm btn-outline-primary">Manage</a>
                        </td>
                    </tr>
                }
                @if (!Model.Orders.Any()) {
                    <tr><td colspan="6" class="text-center text-muted py-4">No orders found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
(function () {
    var form = document.getElementById('ordersFilterForm');
    var searchInput = document.getElementById('orderSearchInput');
    var statusSelect = document.getElementById('statusSelect');
    var debounceTimer;

    searchInput.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function () { form.submit(); }, 400);
    });

    statusSelect.addEventListener('change', function () { form.submit(); });
})();
</script>
}
