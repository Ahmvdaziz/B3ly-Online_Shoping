@model IEnumerable<B3ly.BLL.ViewModels.AdminOrderVM>
@{ ViewData["Title"] = "Orders"; }

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Order #</th><th>Customer</th><th>Date</th>
                    <th>Status</th><th class="text-end">Total</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var o in Model) {
                    var bc = o.Status switch {
                        "Pending"    => "bg-warning text-dark",
                        "Processing" => "bg-info text-dark",
                        "Shipped"    => "bg-primary",
                        "Delivered"  => "bg-success",
                        "Cancelled"  => "bg-danger",
                        _            => "bg-secondary"
                    };
                    <tr>
                        <td><strong>@o.OrderNumber</strong></td>
                        <td>
                            @o.CustomerName
                            <br /><small class="text-muted">@o.CustomerEmail</small>
                        </td>
                        <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge @bc">@o.Status</span></td>
                        <td class="text-end fw-bold">$@o.TotalAmount.ToString("F2")</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@o.OrderId"
                               class="btn btn-sm btn-outline-primary">Manage</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
