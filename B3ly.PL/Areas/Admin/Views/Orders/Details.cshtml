@model B3ly.BLL.ViewModels.AdminOrderVM
@{ ViewData["Title"] = $"Order {Model.OrderNumber}"; }

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <span class="text-muted">Order @Model.OrderNumber</span>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr><th>Product</th><th class="text-center">Qty</th><th class="text-end">Total</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items) {
                            <tr>
                                <td>@item.ProductName<br /><small class="text-muted">$@item.UnitPrice.ToString("F2") each</small></td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">$@item.LineTotal.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="2" class="text-end fw-bold">Total:</td>
                            <td class="text-end fw-bold text-primary">$@Model.TotalAmount.ToString("F2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold">Customer</h6>
                <p class="mb-1">@Model.CustomerName</p>
                <p class="text-muted small mb-3">@Model.CustomerEmail</p>
                <h6 class="fw-bold">Shipping</h6>
                <p class="text-muted small mb-0">@Model.ShippingAddress</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Update Status</h6>
                <form asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="OrderId" value="@Model.OrderId" />
                    <select name="Status" class="form-select mb-3">
                        @foreach (var s in Enum.GetValues<B3ly.DAL.Models.OrderStatus>()) {
                            var isSelected = Model.StatusValue == (int)s;
                            <option value="@((int)s)" selected="@isSelected">@s</option>
                        }
                    </select>
                    <button type="submit" class="btn btn-primary w-100">Update Status</button>
                </form>
            </div>
        </div>
    </div>
</div>
