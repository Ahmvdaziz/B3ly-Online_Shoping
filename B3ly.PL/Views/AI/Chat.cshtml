@using B3ly.BLL.Services
@inject AuthService Auth
@{
    ViewData["Title"] = "AI Assistant";
    Layout = "_Layout";
    var user = Auth.GetCurrentUser();
    var isAdmin = Auth.IsAdmin;
}

<style>
    .chat-wrapper { height: calc(100vh - 130px); display: flex; flex-direction: column; background: #f8faff; }
    .chat-header { background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 60%, #2563eb 100%); color: #fff; padding: 1rem 1.5rem; display: flex; align-items: center; gap: .85rem; }
    .chat-messages { flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: .85rem; scroll-behavior: smooth; }
    .msg-row { display: flex; align-items: flex-end; gap: .5rem; }
    .msg-row.user { flex-direction: row-reverse; }
    .msg-bubble { max-width: 70%; padding: .75rem 1.1rem; border-radius: 18px; line-height: 1.7; font-size: .93rem; white-space: pre-wrap; word-break: break-word; }
    .msg-bubble.user { background: #0d6efd; color: #fff; border-bottom-right-radius: 5px; }
    .msg-bubble.ai { background: #fff; color: #1e293b; border-bottom-left-radius: 5px; box-shadow: 0 1px 8px rgba(0,0,0,.08); }
    .msg-avatar { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .9rem; flex-shrink: 0; }
    .msg-time { font-size: .68rem; color: #94a3b8; margin-top: .25rem; }
    .msg-time.end { text-align: right; }
    .typing-indicator { display: flex; align-items: center; gap: 5px; padding: .75rem 1.1rem; }
    .dot { width: 9px; height: 9px; background: #94a3b8; border-radius: 50%; animation: dotBounce 1.4s infinite ease-in-out; }
    .dot:nth-child(2) { animation-delay: .2s; }
    .dot:nth-child(3) { animation-delay: .4s; }
    @@keyframes dotBounce { 0%,80%,100%{transform:translateY(0);opacity:.5} 40%{transform:translateY(-7px);opacity:1} }
    .chat-suggestions { padding: .6rem 1.25rem .4rem; display: flex; gap: .5rem; flex-wrap: wrap; background: #f8faff; border-top: 1px solid #e9eef6; }
    .suggestion-chip { border: 1.5px solid #dde4f0; border-radius: 20px; padding: .3rem 1rem; font-size: .8rem; cursor: pointer; background: #fff; color: #475569; transition: all .18s; white-space: nowrap; }
    .suggestion-chip:hover { border-color: #0d6efd; background: #eff6ff; color: #0d6efd; }
    .chat-input-bar { border-top: 1px solid #e2e8f0; padding: .875rem 1.25rem .65rem; background: #fff; }
    .chat-input { border-radius: 26px; border: 2px solid #e2e8f0; padding: .6rem 1.25rem; font-size: .93rem; transition: border-color .2s, box-shadow .2s; }
    .chat-input:focus { border-color: #0d6efd; box-shadow: 0 0 0 4px rgba(13,110,253,.1); outline: none; }
    .btn-send { border-radius: 50%; width: 46px; height: 46px; display: flex; align-items: center; justify-content: center; padding: 0; flex-shrink: 0; font-size: 1.05rem; transition: transform .15s; }
    .btn-send:active { transform: scale(.9); }
    .online-dot { width: 10px; height: 10px; background: #4ade80; border-radius: 50%; border: 2px solid #fff; position: absolute; bottom: 2px; right: 2px; }
    .badge-admin { background: linear-gradient(135deg, #dc2626 0%, #991b1b 100%); padding: .35rem .65rem; border-radius: 20px; font-size: .75rem; }
</style>

<div class="container-fluid p-0">
    <div class="chat-wrapper">
        <!-- Header -->
        <div class="chat-header">
            <div class="position-relative">
                <div class="msg-avatar bg-white bg-opacity-20">
                    <i class="bi bi-robot text-white fs-5"></i>
                </div>
                <span class="online-dot"></span>
            </div>
            <div>
                <div class="fw-bold fs-5 lh-1">
                    B3ly AI Assistant
                    @if (isAdmin) { <span class="badge-admin ms-2">👔 Admin Mode</span> }
                </div>
                <div style="font-size:.78rem;opacity:.75;margin-top:.2rem">
                    <i class="bi bi-cpu me-1"></i>phi3 via Ollama &bull; Online
                </div>
            </div>
            <button class="btn btn-sm btn-outline-light ms-auto rounded-pill px-3" id="btnClear">
                <i class="bi bi-arrow-counterclockwise me-1"></i>New Chat
            </button>
        </div>

        <!-- Messages -->
        <div class="chat-messages" id="chatMessages">
            <div class="msg-row" id="welcomeRow">
                <div class="msg-avatar bg-primary text-white">
                    <i class="bi bi-robot"></i>
                </div>
                <div>
                    <div class="msg-bubble ai">
                        <strong>👋 Hi! I'm the B3ly AI Assistant</strong> (powered by phi3 via Ollama)<br><br>
                        @if (isAdmin) {
                            <text>🔍 Admin Mode Active - I can provide business intelligence:<br>• Sales analytics • Top products • Inventory status • Order metrics</text>
                        } else {
                            <text>Customer Mode - I can help with:<br>• Product recommendations • Prices • Orders • Payments</text>
                        }
                        <br><br><strong>What can I help you with?</strong>
                    </div>
                    <div class="msg-time">Just now</div>
                </div>
            </div>
        </div>

        <!-- Suggestions -->
        <div class="chat-suggestions" id="suggestions">
            <span class="text-muted small me-1 align-self-center" style="font-size:.75rem">Try:</span>
            @if (isAdmin) {
                <button class="suggestion-chip" onclick="useSuggestion('What are total sales today?')">Sales today</button>
                <button class="suggestion-chip" onclick="useSuggestion('What are the top selling products?')">Top products</button>
                <button class="suggestion-chip" onclick="useSuggestion('How much stock do we have?')">Stock status</button>
                <button class="suggestion-chip" onclick="useSuggestion('What percentage of stock is low?')">Low stock</button>
            } else {
                <button class="suggestion-chip" onclick="useSuggestion('Recommend home office products')">Home office</button>
                <button class="suggestion-chip" onclick="useSuggestion('Show me cheap laptops')">Budget laptops</button>
                <button class="suggestion-chip" onclick="useSuggestion('What phones are under 500?')">Affordable phones</button>
                <button class="suggestion-chip" onclick="useSuggestion('What items are in stock?')">In stock</button>
            }
        </div>

        <!-- Input -->
        <div class="chat-input-bar">
            <form id="chatForm" class="d-flex gap-2">
                <input type="text" id="chatInput" class="form-control chat-input" placeholder="Ask me anything..." autocomplete="off" />
                <button type="submit" class="btn btn-primary btn-send" id="btnSend" title="Send (Enter)">
                    <i class="bi bi-send-fill"></i>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    let conversationHistory = [];
    let isLoading = false;

    const chatMessages = document.getElementById('chatMessages');
    const chatInput = document.getElementById('chatInput');
    const chatForm = document.getElementById('chatForm');
    const suggestions = document.getElementById('suggestions');
    const btnClear = document.getElementById('btnClear');

    chatForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const question = chatInput.value.trim();
        if (!question || isLoading) return;

        chatInput.value = '';
        suggestions.style.display = 'none';
        isLoading = true;

        addMessage('user', question);
        conversationHistory.push({ role: 'user', content: question });

        const typingId = showTypingIndicator();

        try {
            const response = await fetch('/AI/Ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question })
            });

            if (!response.ok) {
                const error = await response.json();
                throw new Error(error.error || 'Failed to get response');
            }

            const data = await response.json();
            removeTypingIndicator(typingId);

            addMessage('ai', data.answer);
            conversationHistory.push({ role: 'ai', content: data.answer });

            chatMessages.scrollTop = chatMessages.scrollHeight;
        } catch (err) {
            removeTypingIndicator(typingId);
            addMessage('ai', 'Error: ' + err.message);
        } finally {
            isLoading = false;
            chatInput.focus();
        }
    });

    function addMessage(role, content) {
        const isUser = role === 'user';
        const row = document.createElement('div');
        row.className = `msg-row ${isUser ? 'user' : ''}`;

        const avatar = document.createElement('div');
        avatar.className = `msg-avatar ${isUser ? 'bg-primary text-white' : 'bg-light text-primary'}`;
        avatar.innerHTML = isUser ? '<i class="bi bi-person-fill"></i>' : '<i class="bi bi-robot"></i>';

        const bubble = document.createElement('div');
        bubble.className = `msg-bubble ${isUser ? 'user' : 'ai'}`;
        bubble.textContent = content;

        const timeDiv = document.createElement('div');
        timeDiv.className = `msg-time ${isUser ? 'end' : ''}`;
        timeDiv.textContent = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

        const msgDiv = document.createElement('div');
        msgDiv.appendChild(bubble);
        msgDiv.appendChild(timeDiv);

        row.appendChild(avatar);
        row.appendChild(msgDiv);

        const welcome = document.getElementById('welcomeRow');
        if (welcome && isUser) welcome.remove();

        chatMessages.appendChild(row);
        chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function showTypingIndicator() {
        const id = 'typing-' + Date.now();
        const row = document.createElement('div');
        row.id = id;
        row.className = 'msg-row';
        row.innerHTML = `
            <div class="msg-avatar bg-light text-primary">
                <i class="bi bi-robot"></i>
            </div>
            <div class="typing-indicator">
                <div class="dot"></div>
                <div class="dot"></div>
                <div class="dot"></div>
            </div>
        `;
        chatMessages.appendChild(row);
        chatMessages.scrollTop = chatMessages.scrollHeight;
        return id;
    }

    function removeTypingIndicator(id) {
        document.getElementById(id)?.remove();
    }

    function useSuggestion(text) {
        chatInput.value = text;
        chatInput.focus();
        chatForm.dispatchEvent(new Event('submit'));
    }

    btnClear.addEventListener('click', () => {
        if (confirm('Clear conversation?')) {
            chatMessages.innerHTML = '';
            conversationHistory = [];
            suggestions.style.display = 'flex';
            addMessage('ai', 'New chat started. How can I help?');
        }
    });

    chatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            chatForm.dispatchEvent(new Event('submit'));
        }
    });

    chatInput.focus();
</script>
