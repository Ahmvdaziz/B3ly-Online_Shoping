@{
    ViewData["Title"] = "Welcome to B3ly";
    var featured   = ViewBag.FeaturedProducts as IEnumerable<B3ly.BLL.ViewModels.ProductVM> ?? Enumerable.Empty<B3ly.BLL.ViewModels.ProductVM>();
    var categories = ViewBag.Categories       as IEnumerable<B3ly.BLL.ViewModels.CategoryVM> ?? Enumerable.Empty<B3ly.BLL.ViewModels.CategoryVM>();
}
@using B3ly.BLL.Services
@inject AuthService HomeAuth
@{
    var isAdmin = HomeAuth.GetCurrentUser()?.Role == "Admin";
}

<style>
    /* ── Hero ── */
    .hero-section {
        background: linear-gradient(135deg, #0f172a 0%, #1e3a8a 50%, #2563eb 100%);
        min-height: 88vh;
        display: flex;
        align-items: center;
        position: relative;
        overflow: hidden;
    }
    .hero-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: url('https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=1600&q=80&auto=format&fit=crop') center/cover no-repeat;
        opacity: .12;
    }
    .hero-badge { background: rgba(255,255,255,.15); backdrop-filter: blur(8px); border: 1px solid rgba(255,255,255,.25); border-radius: 50px; display: inline-flex; align-items: center; gap: .4rem; padding: .35rem 1rem; font-size: .85rem; color: #fff; margin-bottom: 1.25rem; }
    .hero-title { font-size: clamp(2.4rem, 5vw, 3.8rem); font-weight: 800; line-height: 1.15; color: #fff; letter-spacing: -.02em; }
    .hero-subtitle { font-size: 1.15rem; color: rgba(255,255,255,.78); max-width: 520px; line-height: 1.7; }
    .hero-cta-primary { background: #fff; color: #1e3a8a; font-weight: 700; border-radius: 50px; padding: .75rem 2rem; border: none; transition: transform .2s, box-shadow .2s; }
    .hero-cta-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 30px rgba(0,0,0,.25); color: #1e3a8a; }
    .hero-cta-secondary { background: transparent; color: #fff; font-weight: 600; border-radius: 50px; padding: .75rem 2rem; border: 2px solid rgba(255,255,255,.5); transition: background .2s, border-color .2s; }
    .hero-cta-secondary:hover { background: rgba(255,255,255,.12); border-color: #fff; color: #fff; }
    .hero-stats { display: flex; gap: 2.5rem; margin-top: 2.5rem; }
    .hero-stat-val { font-size: 1.6rem; font-weight: 800; color: #fff; line-height: 1; }
    .hero-stat-label { font-size: .8rem; color: rgba(255,255,255,.6); margin-top: .15rem; }
    .hero-image-wrap { position: relative; }
    .hero-image-wrap img { border-radius: 20px; box-shadow: 0 30px 80px rgba(0,0,0,.45); width: 100%; object-fit: cover; max-height: 480px; }
    .hero-float-card { position: absolute; background: #fff; border-radius: 14px; padding: .75rem 1.1rem; box-shadow: 0 8px 30px rgba(0,0,0,.18); display: flex; align-items: center; gap: .65rem; white-space: nowrap; animation: floatCard 3s ease-in-out infinite; }
    .hero-float-card.card-1 { bottom: 30px; left: -20px; animation-delay: 0s; }
    .hero-float-card.card-2 { top: 30px; right: -15px; animation-delay: 1.5s; }
    @@keyframes floatCard { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

    /* ── Features ── */
    .features-section { background: #f8faff; }
    .feature-icon-wrap { width: 60px; height: 60px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; margin: 0 auto 1rem; }
    .feature-card { border: 0; border-radius: 16px; padding: 1.75rem; text-align: center; box-shadow: 0 2px 16px rgba(0,0,0,.06); transition: transform .25s, box-shadow .25s; height: 100%; }
    .feature-card:hover { transform: translateY(-5px); box-shadow: 0 12px 36px rgba(0,0,0,.1); }

    /* ── How it works ── */
    .step-circle { width: 52px; height: 52px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.2rem; flex-shrink: 0; }
    .step-connector { flex: 1; height: 2px; background: linear-gradient(90deg, #0d6efd 0%, #6ea8fe 100%); margin: 0 .5rem; }

    /* ── Categories ── */
    .cat-card { border: 2px solid transparent; border-radius: 14px; padding: 1.25rem .75rem; text-align: center; text-decoration: none; color: #1e293b; transition: border-color .2s, transform .2s, box-shadow .2s; background: #fff; box-shadow: 0 2px 12px rgba(0,0,0,.06); }
    .cat-card:hover { border-color: #0d6efd; transform: translateY(-4px); box-shadow: 0 10px 28px rgba(13,110,253,.15); color: #0d6efd; }
    .cat-card i { font-size: 2rem; color: #0d6efd; margin-bottom: .5rem; }

    /* ── Products ── */
    .product-card img { height: 210px; object-fit: cover; }

    /* ── CTA ── */
    .cta-section { background: linear-gradient(135deg, #1e3a8a 0%, #2563eb 100%); }
</style>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- HERO                                                                  -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section class="hero-section">
    <div class="container position-relative py-5">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="hero-badge">
                    <i class="bi bi-stars"></i>
                    Trusted by thousands of shoppers
                </div>
                <h1 class="hero-title mb-4">
                    Shop Smarter.<br />
                    <span style="color:#93c5fd">Save Bigger.</span>
                </h1>
                <p class="hero-subtitle mb-4">
                    B3ly brings you thousands of products at unbeatable prices — with fast delivery, secure payments, and a seamless shopping experience.
                </p>
                <div class="d-flex flex-wrap gap-3">
                    <a asp-controller="Catalog" asp-action="Index" class="hero-cta-primary btn">
                        <i class="bi bi-grid-fill me-2"></i>Start Shopping
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="hero-cta-secondary btn">
                        Create Free Account
                    </a>
                </div>
                <div class="hero-stats">
                    <div>
                        <div class="hero-stat-val">10K+</div>
                        <div class="hero-stat-label">Products</div>
                    </div>
                    <div>
                        <div class="hero-stat-val">50K+</div>
                        <div class="hero-stat-label">Happy Customers</div>
                    </div>
                    <div>
                        <div class="hero-stat-val">99%</div>
                        <div class="hero-stat-label">Satisfaction Rate</div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-image-wrap">
                    <img src="https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?w=900&q=80&auto=format&fit=crop"
                         alt="Shopping experience" />
                    <div class="hero-float-card card-1">
                        <div class="bg-success bg-opacity-10 rounded-circle p-2">
                            <i class="bi bi-bag-check-fill text-success fs-5"></i>
                        </div>
                        <div>
                            <div class="fw-bold" style="font-size:.85rem">Order Confirmed!</div>
                            <div class="text-muted" style="font-size:.75rem">Just delivered to you</div>
                        </div>
                    </div>
                    <div class="hero-float-card card-2">
                        <div class="bg-warning bg-opacity-10 rounded-circle p-2">
                            <i class="bi bi-star-fill text-warning fs-5"></i>
                        </div>
                        <div>
                            <div class="fw-bold" style="font-size:.85rem">4.9 / 5 Rating</div>
                            <div class="text-muted" style="font-size:.75rem">Based on 12,000+ reviews</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- FEATURES                                                              -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section class="features-section py-6 py-5">
    <div class="container py-2">
        <div class="text-center mb-5">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-semibold mb-2">Why B3ly?</span>
            <h2 class="fw-bold fs-1">Everything You Need to Shop with Confidence</h2>
            <p class="text-muted fs-5 mt-2">We built B3ly to make online shopping simple, safe, and enjoyable.</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon-wrap bg-primary bg-opacity-10">
                        <i class="bi bi-shield-check text-primary"></i>
                    </div>
                    <h5 class="fw-bold">Secure Payments</h5>
                    <p class="text-muted mb-0">Pay with card via Stripe's industry-leading encryption, or choose Cash on Delivery — your choice.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon-wrap bg-success bg-opacity-10">
                        <i class="bi bi-truck text-success"></i>
                    </div>
                    <h5 class="fw-bold">Fast Delivery</h5>
                    <p class="text-muted mb-0">Your orders are processed and shipped quickly so you get what you want without the wait.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon-wrap bg-warning bg-opacity-10">
                        <i class="bi bi-tag-fill text-warning"></i>
                    </div>
                    <h5 class="fw-bold">Best Prices</h5>
                    <p class="text-muted mb-0">We partner with top suppliers to bring you competitive prices across all categories.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon-wrap bg-info bg-opacity-10">
                        <i class="bi bi-arrow-repeat text-info"></i>
                    </div>
                    <h5 class="fw-bold">Easy Returns</h5>
                    <p class="text-muted mb-0">Not happy? Our simple return process makes it easy to exchange or get a full refund.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon-wrap bg-danger bg-opacity-10">
                        <i class="bi bi-headset text-danger"></i>
                    </div>
                    <h5 class="fw-bold">24/7 Support</h5>
                    <p class="text-muted mb-0">Our support team is always available to help you with any questions or concerns.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon-wrap bg-purple bg-opacity-10" style="background:rgba(124,58,237,.1)">
                        <i class="bi bi-grid-3x3-gap" style="color:#7c3aed;font-size:1.6rem"></i>
                    </div>
                    <h5 class="fw-bold">Wide Selection</h5>
                    <p class="text-muted mb-0">Explore thousands of products across dozens of categories — all in one place.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- HOW IT WORKS                                                          -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section class="py-5 bg-white">
    <div class="container py-2">
        <div class="text-center mb-5">
            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fw-semibold mb-2">Simple Process</span>
            <h2 class="fw-bold fs-1">How It Works</h2>
            <p class="text-muted fs-5 mt-2">Get what you need in just a few steps.</p>
        </div>
        <div class="row g-4 align-items-start">
            <div class="col-md-3 text-center">
                <div class="step-circle bg-primary text-white mx-auto mb-3">1</div>
                <h6 class="fw-bold">Browse &amp; Discover</h6>
                <p class="text-muted small">Explore thousands of products filtered by category, price, or keyword.</p>
            </div>
            <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center pt-3">
                <div class="step-connector"></div>
            </div>
            <div class="col-md-3 text-center">
                <div class="step-circle bg-primary text-white mx-auto mb-3">2</div>
                <h6 class="fw-bold">Add to Cart</h6>
                <p class="text-muted small">Select your items and quantities, then head to your cart to review.</p>
            </div>
            <div class="col-md-1 d-none d-md-flex align-items-center justify-content-center pt-3">
                <div class="step-connector"></div>
            </div>
            <div class="col-md-3 text-center">
                <div class="step-circle bg-primary text-white mx-auto mb-3">3</div>
                <h6 class="fw-bold">Checkout Securely</h6>
                <p class="text-muted small">Enter your shipping address, choose Cash or Card, and place your order.</p>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- CATEGORIES                                                            -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
@if (categories.Any())
{
<section class="py-5 bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">Shop by Category</h2>
                <p class="text-muted mb-0 small">Find exactly what you're looking for</p>
            </div>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary btn-sm">View All</a>
        </div>
        <div class="row g-3">
            @foreach (var cat in categories.Where(c => c.ParentCategoryId == null).Take(6))
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@cat.CategoryId" class="cat-card d-block h-100">
                        <i class="bi bi-tag-fill d-block"></i>
                        <strong class="d-block" style="font-size:.9rem">@cat.Name</strong>
                        <small class="text-muted">@cat.ProductCount items</small>
                    </a>
                </div>
            }
        </div>
    </div>
</section>
}

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- NEW ARRIVALS                                                          -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
@if (featured.Any())
{
<section class="py-5 bg-white">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold mb-0">New Arrivals</h2>
                <p class="text-muted mb-0 small">Fresh picks added just for you</p>
            </div>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary btn-sm">View All</a>
        </div>
        <div class="row g-4">
            @foreach (var p in featured)
            {
                <div class="col-6 col-md-4 col-lg-3">
                    <div class="card product-card h-100 border-0 shadow-sm">
                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@p.ProductId">
                            <img src="@(p.ImageUrl ?? "https://placehold.co/400x400/f1f5f9/94a3b8?text=Product")"
                                 class="card-img-top" alt="@p.Name" />
                        </a>
                        <div class="card-body d-flex flex-column p-3">
                            <small class="text-muted mb-1">@p.CategoryName</small>
                            <h6 class="card-title mb-2 fw-semibold" style="font-size:.9rem">
                                <a asp-controller="Catalog" asp-action="Details" asp-route-id="@p.ProductId"
                                   class="text-decoration-none text-dark stretched-link-alt">@p.Name</a>
                            </h6>
                            <div class="mt-auto">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <span class="fs-5 fw-bold text-primary">$@p.Price.ToString("F2")</span>
                                    @if (p.StockQuantity < 5 && p.StockQuantity > 0)
                                    {
                                        <span class="badge bg-warning text-dark" style="font-size:.7rem">Low Stock</span>
                                    }
                                </div>
                                @if (!isAdmin) {
                                    <form asp-controller="Cart" asp-action="Add" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@p.ProductId" />
                                        <button type="submit" class="btn btn-primary btn-sm w-100">
                                            <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
}

<!-- ══════════════════════════════════════════════════════════════════════ -->
<!-- CALL TO ACTION                                                        -->
<!-- ══════════════════════════════════════════════════════════════════════ -->
<section class="cta-section py-5">
    <div class="container py-3 text-center text-white">
        <h2 class="fw-bold fs-1 mb-3">Ready to Start Shopping?</h2>
        <p class="fs-5 mb-4" style="color:rgba(255,255,255,.8);max-width:520px;margin:0 auto 1.5rem">
            Join thousands of happy customers and discover products you'll love — all at prices you'll appreciate.
        </p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-light btn-lg fw-bold px-4 rounded-pill text-primary">
                <i class="bi bi-grid-fill me-2"></i>Browse Products
            </a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-lg fw-semibold px-4 rounded-pill">
                Create Free Account
            </a>
        </div>
    </div>
</section>
