@model B3ly.BLL.ViewModels.LoginVM
@{
    ViewData["Title"] = "Login";
    var returnUrl = ViewBag.ReturnUrl as string;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow">
                <div class="card-body p-4">
                    <h3 class="fw-bold text-center mb-4"><i class="bi bi-person-circle me-2 text-primary"></i>Sign In</h3>

                    <div asp-validation-summary="All" class="alert alert-danger" style="display:none" id="valSummary"></div>

                    <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" placeholder="you@example.com" autofocus />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <input asp-for="Password" class="form-control" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Login</button>
                    </form>

                    <hr class="my-3" />
                    <p class="text-center mb-0">
                        Don't have an account?
                        <a asp-controller="Account" asp-action="Register" class="fw-bold">Register here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
