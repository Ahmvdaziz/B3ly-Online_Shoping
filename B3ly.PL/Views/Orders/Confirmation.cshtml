@model B3ly.BLL.ViewModels.OrderVM
@{ ViewData["Title"] = "Order Confirmed!"; }

<div class="container py-5 text-center">
    <i class="bi bi-check-circle-fill text-success" style="font-size:5rem"></i>
    <h1 class="fw-bold mt-3">Order Placed Successfully!</h1>
    <p class="text-muted fs-5">Thank you! Your order <strong>@Model.OrderNumber</strong> has been received.</p>
    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-outline-primary btn-lg">View Order</a>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg">Continue Shopping</a>
    </div>
</div>
