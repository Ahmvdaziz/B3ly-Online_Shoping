@model IEnumerable<B3ly.BLL.ViewModels.OrderVM>
@{ ViewData["Title"] = "My Orders"; }

<div class="container py-4">
    <h2 class="fw-bold mb-4"><i class="bi bi-receipt me-2 text-primary"></i>My Orders</h2>

    @if (!Model.Any()) {
        <div class="text-center py-5">
            <i class="bi bi-receipt text-muted" style="font-size:5rem"></i>
            <p class="mt-3 text-muted">You haven't placed any orders yet.</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Start Shopping</a>
        </div>
    } else {
        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Order #</th>
                            <th>Date</th>
                            <th>Status</th>
                            <th>Items</th>
                            <th class="text-end">Total</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model) {
                            var bc = o.Status switch {
                                "Pending"    => "bg-warning text-dark",
                                "Processing" => "bg-info text-dark",
                                "Shipped"    => "bg-primary",
                                "Delivered"  => "bg-success",
                                "Cancelled"  => "bg-danger",
                                _            => "bg-secondary"
                            };
                            <tr>
                                <td><strong>@o.OrderNumber</strong></td>
                                <td>@o.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td><span class="badge @bc">@o.Status</span></td>
                                <td>@o.Items.Count item(s)</td>
                                <td class="text-end fw-bold">$@o.TotalAmount.ToString("F2")</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@o.OrderId"
                                       class="btn btn-sm btn-outline-primary">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
