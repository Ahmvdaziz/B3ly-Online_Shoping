@model B3ly.BLL.ViewModels.OrderVM
@{ ViewData["Title"] = $"Order {Model.OrderNumber}"; }

<div class="container py-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Order @Model.OrderNumber</h2>
        @{ var bc = Model.Status switch {
            "Pending"    => "bg-warning text-dark",
            "Processing" => "bg-info text-dark",
            "Shipped"    => "bg-primary",
            "Delivered"  => "bg-success",
            "Cancelled"  => "bg-danger",
            _            => "bg-secondary"
        }; }
        <span class="badge @bc fs-6">@Model.Status</span>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-center">Unit Price</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items) {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-center">$@item.UnitPrice.ToString("F2")</td>
                                    <td class="text-end">$@item.LineTotal.ToString("F2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">Order Total:</td>
                                <td class="text-end fw-bold text-primary fs-5">$@Model.TotalAmount.ToString("F2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold">Order Info</h6>
                    <dl class="mb-3">
                        <dt class="text-muted small">Date</dt>
                        <dd>@Model.OrderDate.ToString("MMMM dd, yyyy HH:mm")</dd>
                        <dt class="text-muted small">Shipping Address</dt>
                        <dd>@Model.ShippingAddress</dd>
                    </dl>

                    <!-- Cancel Button -->
                    @if (Model.Status == "Pending" || Model.Status == "Processing")
                    {
                        <form method="post" asp-action="CancelOrder" asp-route-id="@Model.OrderId" onsubmit="return confirm('Are you sure you want to cancel this order?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm w-100">
                                <i class="bi bi-x-circle me-1"></i>Cancel Order
                            </button>
                        </form>
                        <small class="text-muted d-block mt-2">
                            <i class="bi bi-info-circle me-1"></i>
                            You can only cancel Pending or Processing orders.
                        </small>
                    }
                    else
                    {
                        <div class="alert alert-info small mb-0" role="alert">
                            <i class="bi bi-lock me-1"></i>
                            This order cannot be cancelled (Status: @Model.Status).
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <a asp-action="Index" class="btn btn-outline-secondary mt-4">
        <i class="bi bi-arrow-left me-1"></i>Back to Orders
    </a>
</div>
