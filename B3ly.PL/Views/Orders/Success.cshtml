@{ ViewData["Title"] = "Payment Successful"; }

<div class="container py-5 text-center">
    <i class="bi bi-check-circle-fill text-success" style="font-size:5rem"></i>
    <h1 class="fw-bold mt-3">Payment Successful!</h1>
    <p class="text-muted fs-5">Thank you! Your payment was processed successfully.</p>
    <div class="d-flex justify-content-center gap-3 mt-4">
        <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-primary btn-lg">My Orders</a>
        <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-lg">Continue Shopping</a>
    </div>
</div>
