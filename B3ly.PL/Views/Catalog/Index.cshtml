@model B3ly.BLL.ViewModels.CatalogIndexVM
@{ ViewData["Title"] = "Shop"; }

<div class="container py-4">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-lg-3">
            <!-- Categories -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-tag me-2 text-primary"></i>Categories</h6>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-1">
                            <a asp-action="Index"
                               asp-route-q="@Model.SearchQuery" asp-route-sort="@Model.Sort"
                               asp-route-minPrice="@Model.MinPrice" asp-route-maxPrice="@Model.MaxPrice"
                               class="text-decoration-none @(Model.SelectedCategoryId == null ? "fw-bold text-primary" : "text-secondary")">
                                All Products
                            </a>
                        </li>
                        @foreach (var cat in Model.Categories) {
                            <li class="mb-1">
                                <a asp-action="Index" asp-route-categoryId="@cat.CategoryId"
                                   asp-route-q="@Model.SearchQuery" asp-route-sort="@Model.Sort"
                                   asp-route-minPrice="@Model.MinPrice" asp-route-maxPrice="@Model.MaxPrice"
                                   class="text-decoration-none @(Model.SelectedCategoryId == cat.CategoryId ? "fw-bold text-primary" : "text-dark")">
                                    @cat.Name <span class="text-muted small">(@cat.ProductCount)</span>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

            <!-- Price Filter -->
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold mb-3"><i class="bi bi-currency-dollar me-2 text-primary"></i>Price Range</h6>
                    <form asp-action="Index" method="get">
                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                        <input type="hidden" name="q"          value="@Model.SearchQuery" />
                        <input type="hidden" name="sort"       value="@Model.Sort" />
                        <div class="mb-2">
                            <label class="form-label small">Min Price ($)</label>
                            <input name="minPrice" type="number" step="0.01" min="0"
                                   value="@Model.MinPrice" class="form-control form-control-sm" placeholder="0" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Max Price ($)</label>
                            <input name="maxPrice" type="number" step="0.01" min="0"
                                   value="@Model.MaxPrice" class="form-control form-control-sm" placeholder="any" />
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm w-100">Apply</button>
                        @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue) {
                            <a asp-action="Index"
                               asp-route-categoryId="@Model.SelectedCategoryId"
                               asp-route-q="@Model.SearchQuery"
                               asp-route-sort="@Model.Sort"
                               class="btn btn-outline-secondary btn-sm w-100 mt-1">Clear Price</a>
                        }
                    </form>
                </div>
            </div>
        </div>

        <!-- Products -->
        <div class="col-lg-9">
            <!-- Toolbar -->
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                <p class="mb-0 text-muted small">
                    Showing <strong>@Model.Products.Count()</strong> of <strong>@Model.TotalCount</strong> products
                    @if (!string.IsNullOrEmpty(Model.SearchQuery)) { <span>for "<em>@Model.SearchQuery</em>"</span> }
                    @if (Model.MinPrice.HasValue || Model.MaxPrice.HasValue) {
                        <span class="ms-1">
                            — price:
                            @(Model.MinPrice.HasValue ? "$" + Model.MinPrice.Value.ToString("F0") : "any")
                            –
                            @(Model.MaxPrice.HasValue ? "$" + Model.MaxPrice.Value.ToString("F0") : "any")
                        </span>
                    }
                </p>
                <form asp-action="Index" method="get" class="d-flex gap-2">
                    <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />
                    <input type="hidden" name="q"          value="@Model.SearchQuery" />
                    <input type="hidden" name="minPrice"   value="@Model.MinPrice" />
                    <input type="hidden" name="maxPrice"   value="@Model.MaxPrice" />
                    <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value=""          selected="@(Model.Sort == null)">Sort: Default</option>
                        <option value="name_asc"  selected="@(Model.Sort=="name_asc")">Name A-Z</option>
                        <option value="price_asc" selected="@(Model.Sort=="price_asc")">Price ↑</option>
                        <option value="price_desc"selected="@(Model.Sort=="price_desc")">Price ↓</option>
                        <option value="newest"   selected="@(Model.Sort=="newest")">Newest</option>
                    </select>
                </form>
            </div>

            @if (!Model.Products.Any()) {
                <div class="text-center py-5">
                    <i class="bi bi-search fs-1 text-muted"></i>
                    <p class="mt-3 text-muted">No products found.</p>
                    <a asp-action="Index" class="btn btn-outline-primary">Clear Filters</a>
                </div>
            } else {
                <div class="row g-4">
                    @foreach (var p in Model.Products) {
                        <div class="col-6 col-md-4">
                            <div class="card product-card h-100 shadow-sm">
                                <a asp-action="Details" asp-route-id="@p.ProductId">
                                    <img src="@(p.ImageUrl ?? "https://placehold.co/400x400?text=Product")"
                                         class="card-img-top" alt="@p.Name" />
                                </a>
                                <div class="card-body d-flex flex-column">
                                    <small class="text-muted">@p.CategoryName</small>
                                    <h6 class="card-title mt-1">
                                        <a asp-action="Details" asp-route-id="@p.ProductId"
                                           class="text-decoration-none text-dark">@p.Name</a>
                                    </h6>
                                    @if (p.StockQuantity is > 0 and <= 5) {
                                        <span class="badge bg-warning text-dark mb-1" style="font-size:.7rem">Only @p.StockQuantity left!</span>
                                    } else if (p.StockQuantity == 0) {
                                        <span class="badge bg-secondary mb-1" style="font-size:.7rem">Out of Stock</span>
                                    }
                                    <div class="mt-auto">
                                        <span class="fs-5 fw-bold text-primary">$@p.Price.ToString("F2")</span>
                                        @if (p.StockQuantity > 0) {
                                            @if (!User.IsInRole("Admin")) {
                                                <form asp-controller="Cart" asp-action="Add" method="post" class="mt-2">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productId" value="@p.ProductId" />
                                                    <button type="submit" class="btn btn-primary btn-sm w-100">
                                                        <i class="bi bi-cart-plus me-1"></i>Add to Cart
                                                    </button>
                                                </form>
                                            }
                                        } else {
                                            <button class="btn btn-secondary btn-sm w-100 mt-2" disabled>Out of Stock</button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (Model.TotalPages > 1) {
                    <nav class="mt-4 d-flex justify-content-center">
                        <ul class="pagination">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-categoryId="@Model.SelectedCategoryId"
                                   asp-route-q="@Model.SearchQuery"
                                   asp-route-sort="@Model.Sort"
                                   asp-route-minPrice="@Model.MinPrice"
                                   asp-route-maxPrice="@Model.MaxPrice"
                                   asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++) {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Index"
                                       asp-route-categoryId="@Model.SelectedCategoryId"
                                       asp-route-q="@Model.SearchQuery"
                                       asp-route-sort="@Model.Sort"
                                       asp-route-minPrice="@Model.MinPrice"
                                       asp-route-maxPrice="@Model.MaxPrice"
                                       asp-route-page="@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-categoryId="@Model.SelectedCategoryId"
                                   asp-route-q="@Model.SearchQuery"
                                   asp-route-sort="@Model.Sort"
                                   asp-route-minPrice="@Model.MinPrice"
                                   asp-route-maxPrice="@Model.MaxPrice"
                                   asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                            </li>
                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>
