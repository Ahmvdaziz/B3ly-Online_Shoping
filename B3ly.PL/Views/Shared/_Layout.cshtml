@using B3ly.BLL.Services
@inject AuthService Auth
@inject CartService Cart
@{
    var currentUser = Auth.GetCurrentUser();
    var cartCount   = Cart.GetCart().ItemCount;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - B3ly Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        /* ============================================================
         *  THEME COLORS — change the values below to restyle the site
         *  --color-primary    : main brand color (navbar, buttons, links)
         *  --color-primary-rgb: same color as R,G,B for rgba() shadows
         *  --color-footer-bg  : footer background
         * ============================================================ */
        :root {
            --color-primary:     #6d28d9;   /* violet-700 */
            --color-primary-rgb: 109,40,217;
            --color-footer-bg:   #1e1033;   /* deep violet-night */
        }

        /* Override Bootstrap 5 primary colour */
        :root {
            --bs-primary:        var(--color-primary);
            --bs-primary-rgb:    var(--color-primary-rgb);
        }
        .btn-primary, .bg-primary { background-color: var(--color-primary) !important; border-color: var(--color-primary) !important; }
        .btn-primary:hover         { background-color: #5b21b6 !important; border-color: #5b21b6 !important; }
        .btn-outline-primary       { color: var(--color-primary) !important; border-color: var(--color-primary) !important; }
        .btn-outline-primary:hover { background-color: var(--color-primary) !important; color: #fff !important; }
        .text-primary              { color: var(--color-primary) !important; }
        .navbar-dark.bg-primary    { background-color: var(--color-primary) !important; }
        .badge.bg-primary          { background-color: var(--color-primary) !important; }
        a                          { color: var(--color-primary); }
        a:hover                    { color: #5b21b6; }

        .navbar-brand  { font-weight: 800; font-size: 1.5rem; }
        .product-card  { transition: transform .2s, box-shadow .2s; border: none; }
        .product-card:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(var(--color-primary-rgb),.18); }
        .product-card img   { height: 220px; object-fit: cover; }
        .cart-badge    { position: absolute; top: -6px; right: -8px; font-size:.65rem; }
        footer         { background: var(--color-footer-bg); color: #c4b5fd; }
        .ai-fab { position:fixed; bottom:1.75rem; right:1.75rem; width:54px; height:54px; background:linear-gradient(135deg,#4c1d95,#7c3aed); color:#fff; border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:1.4rem; box-shadow:0 6px 20px rgba(var(--color-primary-rgb),.45); text-decoration:none; transition:transform .2s,box-shadow .2s; z-index:1050; }
        .ai-fab:hover  { transform:scale(1.12); box-shadow:0 10px 28px rgba(var(--color-primary-rgb),.6); color:#fff; }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <i class="bi bi-bag-heart-fill me-1"></i>B3ly
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Catalog" asp-action="Index">Shop</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="AI" asp-action="Chat">
                        <i class="bi bi-robot me-1"></i>AI Chat
                    </a>
                </li>
            </ul>

            <form class="d-flex me-3" asp-controller="Catalog" asp-action="Index" method="get">
                <input class="form-control form-control-sm me-2" type="search" name="q"
                       placeholder="Search products…" value="@Context.Request.Query["q"]" style="width:220px" />
                <button class="btn btn-light btn-sm" type="submit"><i class="bi bi-search"></i></button>
            </form>

            <ul class="navbar-nav align-items-center gap-2">
                <!-- Cart icon -->
                <li class="nav-item position-relative">
                    <a class="nav-link" asp-controller="Cart" asp-action="Index">
                        <i class="bi bi-cart3 fs-5"></i>
                        @if (cartCount > 0) {
                            <span class="badge bg-danger rounded-pill cart-badge">@cartCount</span>
                        }
                    </a>
                </li>

                @if (currentUser != null)
                {
                    @if (currentUser.Role == "Admin") {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="Index">
                                <i class="bi bi-gear me-1"></i>Admin
                            </a>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Orders" asp-action="Index">
                            <i class="bi bi-receipt me-1"></i>Orders
                        </a>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>@currentUser.FullName
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text text-muted small">@currentUser.Email</span></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="btn btn-outline-light btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-light btn-sm text-primary fw-bold" asp-controller="Account" asp-action="Register">Register</a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<main class="flex-grow-1">
    @if (TempData["Success"] != null) {
        <div class="alert alert-success alert-dismissible fade show m-0 rounded-0">
            <div class="container">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @if (TempData["Error"] != null) {
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0">
            <div class="container">
                <i class="bi bi-exclamation-circle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @RenderBody()
</main>

<footer class="py-4 mt-5">
    <div class="container text-center">
        <p class="mb-0">&copy; @DateTime.Now.Year B3ly Store &mdash; Built with ASP.NET Core MVC</p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)

<a asp-controller="AI" asp-action="Chat" class="ai-fab" title="Ask AI Assistant">
    <i class="bi bi-robot"></i>
</a>
</body>
</html>
